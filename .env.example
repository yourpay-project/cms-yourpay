VITE_API_BASE_URL=/api
# Optional: override Google OAuth redirect URL (default: ${VITE_API_BASE_URL}/auth/google)
# VITE_GOOGLE_AUTH_URL=https://your-backend.com/auth/google
# VITE_APP_VERSION=1.0.0

# Application environment: development | staging | production
VITE_APP_ENV=development

# Sentry configuration
# DSN for Sentry project (leave empty to disable)
VITE_SENTRY_DSN=
# Enable Sentry error reporting (\"true\" to enable, anything else treated as false)
VITE_SENTRY_ENABLED=false
