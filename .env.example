VITE_API_BASE_URL=/api
# Optional: override header brand logo URL. Fallback is development logo if unset.
# VITE_BRAND_LOGO_URL=https://new-cms-stg.yourpay.co.id/images/logo-yourpay-dev.webp
# Optional: override Google OAuth redirect URL (default: ${VITE_API_BASE_URL}/auth/google)
# VITE_GOOGLE_AUTH_URL=https://your-backend.com/auth/google
# VITE_APP_VERSION=1.0.0

# Application environment: development | staging | production
VITE_APP_ENV=development

# Sentry (runtime — used by the app)
# Set both to enable Sentry in the browser:
# - VITE_SENTRY_DSN=<your sentry project DSN>
# - VITE_SENTRY_ENABLED=true
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=false

# Sentry (build-time — used by @sentry/vite-plugin for sourcemap upload on production build)
# Set all three to enable automatic sourcemap upload; leave empty to skip upload.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
